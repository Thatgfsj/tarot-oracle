<?xml version="1.0" encoding="utf-8"?>
<!--
    v0.2.0 (event 000075): the chief website's deep purple-
    black starfield background, ported to Android as a
    static layer-list drawable. Star points are randomly
    placed (seeded at design time, so they don't move
    across launches) — same aesthetic as the
    workspace/tarot/index.html's `body { background: ...}`
    radial-gradient.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="600"
                android:centerX="0.18"
                android:centerY="0.12"
                android:startColor="#28105A"
                android:endColor="#040214" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="600"
                android:centerX="0.82"
                android:centerY="0.88"
                android:startColor="#3C126E"
                android:endColor="#040214" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#0E0428" />
        </shape>
    </item>
</layer-list>
